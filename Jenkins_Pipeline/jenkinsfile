pipeline{
    agent any   

    parameters {
        string(name: 'PLAYBOOK_PATH', defaultValue: '01_Variables_Facts_Jinja2/01_variable_sources.yml', description: 'Ansible Playbook Path')
        string(name: 'INVENTORY_PATH', defaultValue: '01_Variables_Facts_Jinja2/inventory/inventory.yml', description: 'Ansible Inventory Path')
        string(name: 'TAG_NAME', defaultValue: 'project', description: 'AWS resource TAG Name')
        string(name: 'TAG_VALUE', defaultValue: 'strata', description: 'AWS resource TAG Value')
    }

    environment{
        GIT_URL = "https://github.com/iamakshu29/Ansible-end-to-end.git"
        TAG_NAME = "${params.TAG_NAME}"
        TAG_VALUE = "${params.TAG_VALUE}"
        PLAYBOOK_PATH = "${env.WORKSPACE}/${params.PLAYBOOK_PATH}"
    INVENTORY_PATH = "${env.WORKSPACE}/${params.INVENTORY_PATH}"
    } 

    stages{
        stage("Checkout Stage"){
            steps{
                echo "Checking out the code from git repo"
                git(
                    url: "${GIT_URL}",
                    branch: "main",
                    credentialsId: "git_creds"
                )
            }
        }

        stage('Validate Agent') {
            steps {
                sh '''
                    command -v ansible >/dev/null || { echo "Ansible missing"; exit 1; }
                '''
            }
        }

        stage("Run Ansible Playbook to install required Dependencies"){
            steps{
                echo "Running Configuration Playbook"
                sh "ansible-playbook -i $env.INVENTORY_PATH $env.PLAYBOOK_PATH --check"
            }
        }   
    }
    post{
        always{
            echo "Cleaning Workspace"
        }
        success{
            echo "========pipeline executed successfully ========"
        }
        failure{
            echo "========pipeline execution failed========"
        }
    }
}